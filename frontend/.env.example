# Angular uses environment.ts files, not dotenv.
# This file documents the required configuration values.
# Copy the values below into src/environments/environment.development.ts

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Go API
API_BASE_URL=http://localhost:8080/api/v1
